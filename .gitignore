# ==========================================
# Project-Specific Exclusions (Large Data)
# ==========================================

# Ignore all large geospatial data files
*.parquet
*.geojson
*.geoparquet

# Ignore deep learning model weights (e.g. XLM-RoBERTa local files)
*.safetensors
*.bin
*.pt
*.h5
*.onnx

# Ignore the entire local XLM-RoBERTa model folder (it has weights and its own .git folder)
P2_SemanticClassification/disaster-twitter-xlm-ROBERTA-al/

# Ignore documentation reference PDFs to keep repo lightweight
*.pdf

# Ignore QGIS styling/metadata files if they are not needed
*.qmd
